{
  "name": "api",
  "type": "module",
  "version": "0.0.0",
  "module": "src/index.ts",
  "scripts": {
    "dev": "bun run --bun vite dev",
    "build": "bun run --bun vite build",
    "build:standalone": "bun run build && bun build --compile --minify-whitespace --minify-syntax --outfile ./dist/standalone/server ./dist/server/index.mjs",
    "start": "cross-env NODE_ENV=production bun run dist/server/index.mjs",
    "lint": "tsc --noEmit && biome check --write --no-errors-on-unmatched --files-ignore-unknown=true .",
    "format": "tsc --noEmit && biome format --write ."
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/openapi": "^1.4.14",
    "@sinclair/typebox": "^0.34.49",
    "effect": "^3.21.0",
    "elysia": "^1.4.28",
    "keyv": "^5.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "bun-types": "^1.3.11",
    "nitro": "^3.0.260311-beta",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.4"
  }
}
